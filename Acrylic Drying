<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Accurate Color Picker Test</title>
  <style>
    #imageDisplay { max-width: 400px; cursor: crosshair; border: 1px solid #ccc; }
    #colorResult { margin-top: 10px; font-family: sans-serif; }
  </style>
</head>
<body>

<input type="file" id="imageInput" accept="image/*">
<img id="imageDisplay" alt="Upload an image then click to pick a color">
<div id="colorResult">Picked color will appear here</div>

<canvas id="hiddenCanvas" style="display:none;"></canvas>

<script>
const imageInput = document.getElementById('imageInput');
const imageDisplay = document.getElementById('imageDisplay');
const hiddenCanvas = document.getElementById('hiddenCanvas');
const ctx = hiddenCanvas.getContext('2d');
const colorResult = document.getElementById('colorResult');

let naturalImage = null;

// Load image into hidden canvas
imageInput.addEventListener('change', e => {
  const file = e.target.files[0];
  if (!file) return;

  const img = new Image();
  img.onload = () => {
    naturalImage = img;

    // Draw image at natural resolution
    hiddenCanvas.width = img.naturalWidth;
    hiddenCanvas.height = img.naturalHeight;
    ctx.imageSmoothingEnabled = false; 
    ctx.drawImage(img, 0, 0);

    // Display it scaled nicely
    imageDisplay.src = img.src;
    colorResult.textContent = "Click the image to pick a color";
  };
  img.src = URL.createObjectURL(file);
});

// Pick color on click
imageDisplay.addEventListener('click', e => {
  if (!naturalImage) return;

  const rect = imageDisplay.getBoundingClientRect();
  const scaleX = naturalImage.naturalWidth / rect.width;
  const scaleY = naturalImage.naturalHeight / rect.height;

  const x = Math.floor((e.clientX - rect.left) * scaleX);
  const y = Math.floor((e.clientY - rect.top) * scaleY);

  const pixel = ctx.getImageData(x, y, 1, 1).data;
  const [r, g, b] = pixel;

  const hex = "#" + ((1 << 24) + (r << 16) + (g << 8) + b)
                   .toString(16).slice(1).toUpperCase();

  colorResult.innerHTML = `
    <div style="display:flex;align-items:center;gap:10px;">
      <div style="width:30px;height:30px;background:rgb(${r},${g},${b});border:1px solid #000;"></div>
      <span>RGB: (${r}, ${g}, ${b}) — HEX: ${hex}</span>
    </div>
  `;
});
</script>

</body>
</html>
