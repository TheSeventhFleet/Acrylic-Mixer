<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vallejo Acrylic Mixer - Wet & Dry Display</title>
<style>
body { font-family: Arial, sans-serif; background: #f4f4f4; padding: 20px; }
.container { display: flex; flex-wrap: wrap; gap: 20px; }
.controls { flex: 1 1 300px; max-height: 600px; overflow-y: auto; border-right:1px solid #ccc; padding-right:10px; }
.previews { flex: 1 1 300px; display: flex; gap: 10px; margin-bottom:10px; }
.preview { flex:1; height: 200px; border:1px solid #ccc; border-radius:8px; }
.slider-container { display: flex; align-items: center; margin-bottom: 5px; gap:5px; flex-wrap: wrap; }
.slider-container input[type=range] { flex:1; }
.swatch { display: inline-block; width: 14px; height: 14px; border:1px solid #000; }
#imagePreview { max-width: 300px; max-height: 200px; display:block; margin-bottom: 10px; border:1px solid #ccc; cursor:crosshair; }
.suggestions { margin-top:10px; background:#fff; padding:10px; border-radius:5px; border:1px solid #ccc; }
</style>
</head>
<body>
<h1>Vallejo Acrylic Mixer</h1>
<div class="container">
  <div class="controls" id="controls"></div>
  <div>
    <div class="previews">
      <div class="preview" id="previewWet" title="Wet"></div>
      <div class="preview" id="previewDry" title="Dry"></div>
    </div>
    <img id="imagePreview" alt="Upload image to pick color">
    <input type="file" id="imageInput" accept="image/*">
    <div class="suggestions" id="suggestions"></div>
  </div>
</div>
<canvas id="imageCanvas" style="display:none;"></canvas>
<script>
// Demo pigments
const pigments = [
  {code:'70.901', name:'Pastel Blue', line:'Model Color', family:'Blues', hex:'#7fa9e1'},
  {code:'70.930', name:'Dark Blue', line:'Model Color', family:'Blues', hex:'#1f3a93'},
  {code:'71001', name:'Air White', line:'Model Air', family:'Whites', hex:'#f7f7f7'},
  {code:'71015', name:'Air Red', line:'Model Air', family:'Reds', hex:'#c92f2d'},
  {code:'777', name:'Ork Skin', line:'Game Color', family:'Skin Tones', hex:'#8c7c55'},
  {code:'700', name:'Chaos Black', line:'Game Color', family:'Whites/Greys', hex:'#111111'},
  {code:'70990', name:'Flat Yellow', line:'Model Color', family:'Yellows', hex:'#f9ea36'},
  {code:'70822', name:'Flat Green', line:'Model Color', family:'Greens', hex:'#1b6e20'},
  {code:'70925', name:'Orange', line:'Model Color', family:'Oranges', hex:'#ff7f2a'},
  {code:'70927', name:'Flat Brown', line:'Model Color', family:'Browns', hex:'#7a5230'}
];

const pigmentsByFamily = {};
pigments.forEach(p => {
  if(!pigmentsByFamily[p.family]) pigmentsByFamily[p.family]=[];
  pigmentsByFamily[p.family].push(p);
});

const controlsDiv = document.getElementById('controls');
const previewWet = document.getElementById('previewWet');
const previewDry = document.getElementById('previewDry');
const imageInput = document.getElementById('imageInput');
const imagePreview = document.getElementById('imagePreview');
const imageCanvas = document.getElementById('imageCanvas');
const ctx = imageCanvas.getContext('2d');
const suggestionsDiv = document.getElementById('suggestions');

// Create sliders
function createSliders() {
  controlsDiv.innerHTML = '';
  Object.keys(pigmentsByFamily).forEach(family => {
    const header = document.createElement('h3');
    header.textContent = family;
    controlsDiv.appendChild(header);
    pigmentsByFamily[family].forEach(p => {
      const container = document.createElement('div');
      container.className='slider-container';

      const swatch = document.createElement('span');
      swatch.className='swatch';
      swatch.style.backgroundColor=p.hex;
      container.appendChild(swatch);

      const label = document.createElement('label');
      label.textContent=p.name;
      container.appendChild(label);

      const slider = document.createElement('input');
      slider.type='range'; slider.min=0; slider.max=100; slider.value=0;
      slider.dataset.hex=p.hex;

      const percent = document.createElement('span');
      percent.textContent='0%';

      const previewSwatch = document.createElement('span');
      previewSwatch.className='swatch';
      previewSwatch.style.border='1px solid #555';
      container.appendChild(previewSwatch);

      slider.addEventListener('input', ()=>{
        percent.textContent=slider.value+'%';
        updateMix();
      });

      container.appendChild(slider);
      container.appendChild(percent);
      controlsDiv.appendChild(container);
    });
  });
}

// HEX to RGB
function hexToRgb(hex){
  const bigint = parseInt(hex.replace('#',''),16);
  return {r:(bigint>>16)&255, g:(bigint>>8)&255, b:bigint&255};
}

// Update mix for wet and dry
function updateMix(){
  let r=0,g=0,b=0,total=0;
  controlsDiv.querySelectorAll('.slider-container').forEach(container=>{
    const slider=container.querySelector('input[type=range]');
    const weight=parseInt(slider.value);
    const rgb=hexToRgb(slider.dataset.hex);
    if(weight>0){ r+=rgb.r*weight; g+=rgb.g*weight; b+=rgb.b*weight; total+=weight; }

    const previewSwatch = container.querySelectorAll('.swatch')[1];
    previewSwatch.style.backgroundColor=`rgb(${rgb.r},${rgb.g},${rgb.b})`;
  });

  let rWet=r,gWet=g,bWet=b;
  if(total>0){ rWet=Math.round(r/total); gWet=Math.round(g/total); bWet=Math.round(b/total); }
  let rDry=Math.round(rWet*0.85), gDry=Math.round(gWet*0.85), bDry=Math.round(bWet*0.85);

  previewWet.style.backgroundColor=`rgb(${rWet},${gWet},${bWet})`;
  previewDry.style.backgroundColor=`rgb(${rDry},${gDry},${bDry})`;
}

// Image upload
imageInput.addEventListener('change', e=>{
  const file=e.target.files[0];
  if(!file) return;
  const img=new Image();
  img.onload=()=>{
    imageCanvas.width=imagePreview.width;
    imageCanvas.height=imagePreview.height;
    ctx.drawImage(img,0,0,imageCanvas.width,imageCanvas.height);
    imagePreview.src=img.src;
    suggestionsDiv.innerHTML='';
  };
  img.src=URL.createObjectURL(file);
});

// Pick color from image
imagePreview.addEventListener('click', e=>{
  const rect=imagePreview.getBoundingClientRect();
  const x=Math.floor(e.clientX-rect.left);
  const y=Math.floor(e.clientY-rect.top);
  const pixel=ctx.getImageData(x,y,1,1).data;
  suggestMix(pixel[0],pixel[1],pixel[2]);
});

// Suggest top 3 pigments
function suggestMix(r,g,b){
  const distances=pigments.map(p=>{
    const c=hexToRgb(p.hex);
    return {pigment:p, dist:Math.sqrt((c.r-r)**2 + (c.g-g)**2 + (c.b-b)**2)};
  });
  distances.sort((a,b)=>a.dist-b.dist);
  const top3=distances.slice(0,3);
  controlsDiv.querySelectorAll('input[type=range]').forEach(s=>s.value=0);
  top3.forEach(d=>{
    const slider=Array.from(controlsDiv.querySelectorAll('input[type=range]')).find(s=>s.dataset.hex===d.pigment.hex);
    if(slider) slider.value=Math.round(100/top3.length);
  });
  updateMix();
  suggestionsDiv.innerHTML='<strong>Suggested mix:</strong><br>'+top3.map(d=>`${d.pigment.name} (${d.pigment.line}) ~ ${Math.round(100/top3.length)}%`).join('<br>');
}

createSliders();
updateMix();
</script>
</body>
</html>
