<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Acrylic Paint Mixer Pro</title>

<style>
body {
  font-family: Arial;
  text-align: center;
  background: #f4f4f4;
}

.preview {
  width: 150px;
  height: 150px;
  border: 2px solid black;
  display: inline-block;
  margin: 10px;
}

select, input {
  margin: 5px;
}

.savedMix {
  cursor: pointer;
  margin: 5px;
  padding: 5px;
  border: 1px solid black;
  display: inline-block;
  background: white;
}
</style>
</head>

<body>

<h1>🎨 Acrylic Paint Mixer Pro</h1>

<!-- ---------------- COLORS ---------------- -->
<div>
  Color 1:
  <select id="p1"></select>
  <input type="range" id="w1" min="0" max="100" value="50">
</div>

<div>
  Color 2:
  <select id="p2"></select>
  <input type="range" id="w2" min="0" max="100" value="50">
</div>

<div>
  Color 3:
  <select id="p3"></select>
  <input type="range" id="w3" min="0" max="100" value="0">
</div>

<button onclick="mixPaints()">Mix</button>

<!-- ---------------- PREVIEW ---------------- -->
<h2>Results</h2>

<div>
  <p>Wet</p>
  <div id="wetDiv" class="preview"></div>
</div>

<div>
  <p>Dry</p>
  <div id="dryDiv" class="preview"></div>
</div>

<!-- ---------------- CALIBRATION ---------------- -->
<h3>Dry Calibration</h3>

Darken:
<input type="range" id="dryDarken" min="0.7" max="1" step="0.01" value="0.9"><br>

Saturation:
<input type="range" id="drySaturation" min="0.8" max="1.5" step="0.01" value="1.1"><br>

Contrast:
<input type="range" id="dryContrast" min="0.8" max="1.5" step="0.01" value="1.1"><br>

<!-- ---------------- SAVE / LOAD ---------------- -->
<h3>Saved Mixes</h3>

<input type="text" id="mixName" placeholder="Mix name">
<button onclick="saveMix()">Save Mix</button>

<div id="savedList"></div>

<script>
// ---------------- PIGMENTS ----------------
const pigments = {
  ultramarine: {name:"Ultramarine Blue", hex:"#3f48cc", strength:0.8},
  hansaYellow: {name:"Hansa Yellow", hex:"#ffcc00", strength:1.0},
  cadmiumRed: {name:"Cadmium Red", hex:"#e32636", strength:1.2},
  titaniumWhite: {name:"Titanium White", hex:"#ffffff", strength:0.5}
};

// Populate dropdowns
function loadPigments() {
  let selects = [p1, p2, p3];
  selects.forEach(sel => {
    for (let key in pigments) {
      let opt = document.createElement("option");
      opt.value = key;
      opt.textContent = pigments[key].name;
      sel.appendChild(opt);
    }
  });
}

// ---------------- COLOR HELPERS ----------------
function hexToRgb(hex){
  let bigint = parseInt(hex.slice(1), 16);
  return {
    r: ((bigint >> 16) & 255)/255,
    g: ((bigint >> 8) & 255)/255,
    b: (bigint & 255)/255
  };
}

function rgbToHex(r,g,b){
  return "#" + [r,g,b].map(x =>
    Math.round(x*255).toString(16).padStart(2,'0')
  ).join('');
}

function toLinear(c){
  return c<=0.04045 ? c/12.92 : Math.pow((c+0.055)/1.055,2.4);
}

function toSRGB(c){
  return c<=0.0031308 ? 12.92*c : 1.055*Math.pow(c,1/2.4)-0.055;
}

// ---------------- MIXING ----------------
function mixPaints(){
  let inputs = [
    {p:pigments[p1.value], w:+w1.value},
    {p:pigments[p2.value], w:+w2.value},
    {p:pigments[p3.value], w:+w3.value}
  ];

  let total = inputs.reduce((s,x)=>s+x.w,0);
  if(total===0) return;
  inputs.forEach(x=>x.w/=total);

  let r=1,g=1,b=1;

  inputs.forEach(({p,w})=>{
    let c = hexToRgb(p.hex);
    let weight = w * p.strength;

    r *= Math.pow(toLinear(c.r), weight);
    g *= Math.pow(toLinear(c.g), weight);
    b *= Math.pow(toLinear(c.b), weight);
  });

  let wet = {
    r: toSRGB(r),
    g: toSRGB(g),
    b: toSRGB(b)
  };

  // ---- DRY CALIBRATION ----
  let darken = +dryDarken.value;
  let sat = +drySaturation.value;
  let contrast = +dryContrast.value;

  let avg = (wet.r+wet.g+wet.b)/3;

  let dry = {
    r: Math.pow(wet.r * darken, contrast),
    g: Math.pow(wet.g * darken, contrast),
    b: Math.pow(wet.b * darken, contrast)
  };

  dry.r = avg + (dry.r-avg)*sat;
  dry.g = avg + (dry.g-avg)*sat;
  dry.b = avg + (dry.b-avg)*sat;

  // Clamp
  for (let k in dry){
    dry[k] = Math.min(1, Math.max(0, dry[k]));
  }

  wetDiv.style.backgroundColor = rgbToHex(wet.r,wet.g,wet.b);
  dryDiv.style.backgroundColor = rgbToHex(dry.r,dry.g,dry.b);
}

// ---------------- SAVE / LOAD ----------------
function saveMix(){
  let name = mixName.value || "Unnamed";

  let mix = {
    name,
    p1:p1.value, w1:w1.value,
    p2:p2.value, w2:w2.value,
    p3:p3.value, w3:w3.value,
    darken:dryDarken.value,
    sat:drySaturation.value,
    contrast:dryContrast.value
  };

  let saved = JSON.parse(localStorage.getItem("mixes") || "[]");
  saved.push(mix);
  localStorage.setItem("mixes", JSON.stringify(saved));

  renderSaved();
}

function loadMix(mix){
  p1.value = mix.p1;
  w1.value = mix.w1;
  p2.value = mix.p2;
  w2.value = mix.w2;
  p3.value = mix.p3;
  w3.value = mix.w3;

  dryDarken.value = mix.darken;
  drySaturation.value = mix.sat;
  dryContrast.value = mix.contrast;

  mixPaints();
}

function renderSaved(){
  let saved = JSON.parse(localStorage.getItem("mixes") || "[]");
  savedList.innerHTML = "";

  saved.forEach(mix=>{
    let div = document.createElement("div");
    div.className = "savedMix";
    div.textContent = mix.name;
    div.onclick = ()=>loadMix(mix);
    savedList.appendChild(div);
  });
}

// ---------------- INIT ----------------
loadPigments();
renderSaved();
</script>

</body>
</html>
